<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Way2Automation Suite">
    <listeners>
        <listener class-name="io.qameta.allure.testng.AllureTestNg"/>
        <listener class-name="com.haritonov.uitests.listeners.ScreenshotListener"/>
        <listener class-name="com.haritonov.uitests.listeners.RetryTransformer"/>
    </listeners>
    <test name="Home Page Tests">
        <classes>
            <class name="com.haritonov.uitests.tests.homepage.HomePageTest"/>
        </classes>
    </test>
    <test name="Navigation Tests">
        <classes>
            <class name="com.haritonov.uitests.tests.navigation.NavigationTest"/>
        </classes>
    </test>
    <test name="Login Page Tests">
        <classes>
            <class name="com.haritonov.uitests.tests.login.LoginPageTest"/>
        </classes>
    </test>
    <test name="Banking Manager Tests">
        <classes>
            <class name="com.haritonov.uitests.tests.banking.BankingManagerPageTest"/>
        </classes>
    </test>
    <test name="Customer Login Tests">
        <classes>
            <class name="com.haritonov.uitests.tests.banking.CustomerLoginTest"/>
        </classes>
    </test>
    <test name="Sample Form Tests">
        <classes>
            <class name="com.haritonov.uitests.tests.banking.SampleFormTest"/>
        </classes>
    </test>
    <test name="Fail test">
        <classes>
            <class name="com.haritonov.uitests.tests.fail.FailTest"/>
        </classes>
    </test>
    <test name="Cookie test">
        <classes>
            <class name="com.haritonov.uitests.tests.cookies.CookieTest"/>
        </classes>
    </test>
    <test name="JavaScript test">
        <classes>
            <class name="com.haritonov.uitests.tests.javascript.JavaScriptExecutorTest"/>
        </classes>
    </test>
</suite>